# Laboratorio 4: Consultas SPARQL
# Integrantes:
# - Gonzalo Sobarzo

# P1: Consulta que obtiene los Q-code de las entidades que tengan la rdfs:label "Universidad de Chile"
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX wikibase: <http://wikiba.se/ontology#>
PREFIX bd: <http://www.bigdata.com/rdf#>

SELECT ?item WHERE {
  ?item rdfs:label "Universidad de Chile"@es .

  SERVICE wikibase:label { bd:serviceParam wikibase:language "es,en". }
}

# Donde ?item es el Q-code de la entidad que tiene el rdfs:label "Universidad de Chile" y wd:Q232141 es el código correspondiente a 
# la Universidad.

# P2: Cadena de clases de las que la Universidad de Chile es instancia.
PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX wikibase: <http://wikiba.se/ontology#>
PREFIX bd: <http://www.bigdata.com/rdf#>

SELECT DISTINCT ?class ?classLabel WHERE {
  wd:Q232141 wdt:P31/wdt:P279* ?class .
  SERVICE wikibase:label { bd:serviceParam wikibase:language "es,en". }
}

# Donde wdt:P31 es la propiedad "instancia de" y wdt:P279 es la propiedad "subclase de".

# P3: Etiquetas de universidades de América del Sur fundadas antes que la U. de Chile
PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX wikibase: <http://wikiba.se/ontology#>
PREFIX bd: <http://www.bigdata.com/rdf#>

SELECT DISTINCT ?university ?universityLabel WHERE {
  wd:Q232141 wdt:P571 ?uchileDate .
  BIND(YEAR(?uchileDate) AS ?uchileYear)

  ?university wdt:P31/wdt:P279* wd:Q3918 ;
              wdt:P571 ?foundingDate ;
              wdt:P17 ?country .

  ?country wdt:P30 wd:Q18 .

  FILTER(YEAR(?foundingDate) < ?uchileYear)

  SERVICE wikibase:label { bd:serviceParam wikibase:language "es,en". }
}

# Donde wdt:P571 es la propiedad "fecha de fundación", wdt:P17 es la propiedad "país", wdt:P30 es la propiedad "continente" y wd:Q18 
# es el código de América del Sur.


# P4: Personas que estudiaron en la U. de Chile y en otra universidad chilena
PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX wikibase: <http://wikiba.se/ontology#>
PREFIX bd: <http://www.bigdata.com/rdf#>

SELECT DISTINCT ?person ?otherUniversity WHERE {
  ?person wdt:P69 wd:Q232141 ;
          wdt:P69 ?otherUniversity .

  FILTER(?otherUniversity != wd:Q232141)

  ?otherUniversity wdt:P31/wdt:P279* wd:Q3918 ;  # universidad (o subtipo)
                   wdt:P17 wd:Q298 .             # Chile

  SERVICE wikibase:label { bd:serviceParam wikibase:language "es,en". }
}
ORDER BY ?personLabel ?otherUniversityLabel

# Donde wdt:P69 es la propiedad "educación", wd:Q232141 es el código de la Universidad de Chile, wd:Q3918 es el código de universidad y 
# wd:Q298 es el código de Chile.

# P5: Contar cuántos ex alumnos de la U. de Chile hay por cada ocupación distinta, ordenados de mayor a menor
PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX wikibase: <http://wikiba.se/ontology#>
PREFIX bd: <http://www.bigdata.com/rdf#>

SELECT ?occupation ?occupationLabel (COUNT(DISTINCT ?person) AS ?count) WHERE {
  ?person wdt:P69 wd:Q232141 ;
          wdt:P106 ?occupation .

  SERVICE wikibase:label { bd:serviceParam wikibase:language "es,en". }
}
GROUP BY ?occupation ?occupationLabel
ORDER BY DESC(?count)

# Donde wdt:P106 es la propiedad "ocupación", wd:Q232141 es el código de la Universidad de Chile.

# P6: Obtener las etiquetas de ex alumnos de la U. de Chile que hayan recibido un premio o distinción (wdt:P166)
PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX p: <http://www.wikidata.org/prop/>
PREFIX ps: <http://www.wikidata.org/prop/statement/>
PREFIX pq: <http://www.wikidata.org/prop/qualifier/>
PREFIX wikibase: <http://wikiba.se/ontology#>
PREFIX bd: <http://www.bigdata.com/rdf#>

SELECT DISTINCT ?person ?personLabel ?award ?awardLabel ?year WHERE {
  ?person wdt:P69 wd:Q232141 ;
          p:P166 ?awardStatement .

  ?awardStatement ps:P166 ?award .
  OPTIONAL { ?awardStatement pq:P585 ?awardDate . }
  BIND(YEAR(?awardDate) AS ?year)

  SERVICE wikibase:label { bd:serviceParam wikibase:language "es,en". }
}
ORDER BY ?year ?personLabel

# Donde wdt:P69 es la propiedad "educación", wd:Q232141 es el código de la Universidad de Chile, p:P166 es la propiedad de 
# declaración para premios.

# P7: etiquetas de las personas que hayan estudiado o trabajado en la Universidad de Chile.
PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX wikibase: <http://wikiba.se/ontology#>
PREFIX bd: <http://www.bigdata.com/rdf#>

SELECT DISTINCT ?personLabel ?role ?birthDate ?countryLabel WHERE {
  {
    ?person wdt:P69 wd:Q232141 .
    BIND("estudiante" AS ?role)
  }
  UNION
  {
    ?person wdt:P108 wd:Q232141 .
    BIND("trabajador" AS ?role)
  }

  OPTIONAL { ?person wdt:P569 ?birthDate . }
  OPTIONAL {
    ?person wdt:P19 ?birthPlace .
    ?birthPlace wdt:P17 ?country .
  }

  SERVICE wikibase:label { bd:serviceParam wikibase:language "es,en". }
}

# Donde wdt:P69 es la propiedad "educación", wdt:P108 es la propiedad "empleador", wd:Q232141 es el código de la Universidad de Chile, 
# wdt:P569 es la propiedad "fecha de nacimiento", wdt:P19 es la propiedad "lugar de nacimiento"

# P8: ex alumnos de la Universidad de Chile, a aquellos que aún están vivos y que tienen una edad mayor al promedio de 
# edad de los ex alumnos vivos.
PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX wikibase: <http://wikiba.se/ontology#>
PREFIX bd: <http://www.bigdata.com/rdf#>

SELECT ?person ?personLabel ?age WHERE {
  ?person wdt:P69 wd:Q232141 ;
          wdt:P569 ?birthDate .

  FILTER NOT EXISTS { ?person wdt:P570 ?deathDate }

  BIND(YEAR(NOW()) - YEAR(?birthDate) AS ?age)

  {
    SELECT (AVG(?avgAge) AS ?averageAge) WHERE {
      ?p wdt:P69 wd:Q232141 ;
         wdt:P569 ?bd .
      FILTER NOT EXISTS { ?p wdt:P570 ?dd }
      BIND(YEAR(NOW()) - YEAR(?bd) AS ?avgAge)
    }
  }

  FILTER(?age > ?averageAge)

  SERVICE wikibase:label { bd:serviceParam wikibase:language "es,en". }
}
ORDER BY ASC(?age)

# Donde wdt:P69 es la propiedad "educación", wd:Q232141 es el código de la Universidad de Chile, 
# wdt:P569 es la propiedad "fecha de nacimiento" y wdt:P570 es la propiedad "fecha de muerte".
# Se observa que hay gente de mas de 125 años, lo que sugiere que hay datos erróneos en Wikidata.
